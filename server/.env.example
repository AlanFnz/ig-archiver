# Copy this file to .env and fill in your values.

# Preferred secret configuration. The dashboard can store a local key instead.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port for the Express server (default: 3000)
PORT=3000

# Local-only by default. Do not expose the unauthenticated dashboard publicly.
HOST=127.0.0.1

# Optional directory for SQLite, screenshots, session.json, and config.json
# DATA_DIR=/absolute/path/to/ig-archiver-data

# Screenshot dimensions (optional overrides)
SCREENSHOT_WIDTH=1280
SCREENSHOT_HEIGHT=720

# Capture behavior (all can also be changed in the dashboard)
CONCURRENCY=3
TIMEOUT_MS=30000
RETRY_ATTEMPTS=3
RETRY_BASE_MS=750

# OpenAI-compatible provider settings
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Set to true to skip OpenAI calls and return fake summaries (useful for testing)
# MOCK=true
