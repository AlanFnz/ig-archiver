# Copy this file to .env and fill in your values.

# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port for the Express server (default: 3000)
PORT=3000

# Screenshot dimensions (optional overrides)
SCREENSHOT_WIDTH=1280
SCREENSHOT_HEIGHT=720

# Capture behavior (all can also be changed in the dashboard)
CONCURRENCY=3
TIMEOUT_MS=30000

# OpenAI-compatible provider settings
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Set to true to skip OpenAI calls and return fake summaries (useful for testing)
# MOCK=true
